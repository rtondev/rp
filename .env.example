# URL pública da API (obrigatório na Vercel).
# Produção: https://api.rotapotiguar.com
# Dev local: deixe vazio para usar o proxy /api abaixo.
NEXT_PUBLIC_API_URL=

# Destino do proxy em desenvolvimento (next.config rewrites).
# Só usado quando NEXT_PUBLIC_API_URL está vazio.
# Portas do projeto:
#   Dev:  API 3001, Postgres 5433
#   VPS:  API 6000 (ver rp-api/.env.production.example)
# Portas ocupadas na VPS (não usar): 1000, 2000, 3307, 5000, 5050, 8080, 25565
API_PROXY_URL=http://localhost:3001
